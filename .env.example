# .env.example — copy to .env and fill in your keys
# Troll 🧌 reads these automatically via pydantic-settings

# ── LLM providers (add the ones you use) ──────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AI...

# ── Troll defaults (optional overrides) ───────────────────────────────────
# TROLL_DEFAULT_PROVIDER=openai
# TROLL_DEFAULT_MODEL_TIER=mid
# TROLL_DEFAULT_ARTIFACTS_DIR=./troll_artifacts
